# ---- LLM (OpenAI-compatible API) ----
# Any endpoint that speaks /v1/chat/completions AND supports function/tool calling.
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-xxxx
LLM_MODEL=gpt-4o-mini

# ---- Google Sheets (service account) ----
# The spreadsheet ID is the long token in the sheet URL:
#   https://docs.google.com/spreadsheets/d/<THIS_PART>/edit
GOOGLE_SHEET_ID=your-spreadsheet-id
# Optional worksheet/tab name; defaults to the first worksheet.
GOOGLE_WORKSHEET=Responses

# Provide the service-account key ONE of two ways:
#  (A) the whole JSON blob inline (single-quote it so newlines in private_key survive):
GOOGLE_SA_JSON=
#  (B) OR a path to the mounted JSON key file (takes effect only if GOOGLE_SA_JSON is empty):
GOOGLE_SA_KEY_PATH=/run/secrets/service_account.json

# ---- Survey ----
SURVEY_PATH=agent/survey.yaml

# ---- Agent session store (SQLite) ----
# Each TUI launch is a fresh survey session; it is deleted when you close the TUI.
AGENT_DB_PATH=data/agent.db

# ---- Web terminal (docker-compose.web.yml only) ----
# Browser "web SSH" into the quarantine container. Basic-auth gate on the web port.
# REQUIRED — the container REFUSES to start until BOTH are set (no defaults shipped
# on purpose: a shipped password = an open shell). Pick a STRONG password; it guards
# a shell. Never commit a real one.
WEB_USER=
WEB_PASS=
# Host port to publish the terminal on (container always listens on 7681).
WEB_PORT=7681
